{
  "name": "careconnect-desktop",
  "version": "1.0.0",
  "description": "CareConnect Desktop — Low-vision accessibility companion for caregivers",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "node build.js && electron-builder --mac --dir",
    "dist": "node build.js && electron-builder --mac"
  },
  "build": {
    "appId": "com.swen661.careconnect",
    "productName": "CareConnect",
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [{ "target": "dmg", "arch": ["x64"] }]
    },
    "files": ["src/**/*", "package.json"],
    "directories": { "output": "dist" }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "babel-jest": "^29.7.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.21.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.[tj]sx?$": "babel-jest"
    },
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "collectCoverageFrom": [
      "src/renderer/**/*.{ts,tsx}",
      "!src/renderer/index.tsx"
    ]
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ],
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ],
      "@babel/preset-typescript"
    ]
  }
}
